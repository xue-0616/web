# ─────────────────────────────────────────────────────────────────────
# .env.integration.example
#
# Copy to `.env.integration` at repo root, then fill in values. The
# compose file enforces `:?` on truly mandatory vars so it will refuse
# to start if any of them are still empty.
#
#   cp docs/env.integration.example .env.integration
#   $EDITOR .env.integration
#   docker compose -f docker-compose.integration.yml --env-file .env.integration up --build
#
# Nothing here should ever be committed. `.env.integration` is already
# in `.gitignore`.
# ─────────────────────────────────────────────────────────────────────

# ─── MySQL ───────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=integration
MYSQL_USER=integration
MYSQL_PASSWORD=changeme_user

# ─── Shared chain RPC endpoints (devnet/testnet for rehearsal) ──────
# Solana: e.g. https://api.devnet.solana.com
SOLANA_RPC_URL=
# CKB: e.g. https://testnet.ckb.dev/ or a devnet node
CKB_RPC_URL=
# BTC: e.g. a btc-assets dev electrs/esplora endpoint
BTC_RPC_URL=

# ─── solagram-backend ────────────────────────────────────────────────
# 32-byte hex (64 chars) — used to encrypt wallet keyblobs at rest.
# Generate once with: openssl rand -hex 32
KEYBLOB_ENCRYPTION_KEY=
JWT_SECRET=dev_jwt_secret_change_me
TELEGRAM_BOT_TOKEN=
SENTRY_DSN_SOLAGRAM=

# ─── mystery-bomb-box-backend ───────────────────────────────────────
# Operator keypair used to sign bomb-box Solana transactions.
# Base58 secret key. DEVNET ONLY for rehearsal — never use mainnet here.
BOMB_BOX_OPERATOR_KEY=
SENTRY_DSN_BOMBBOX=

# ─── btc-assets-api ──────────────────────────────────────────────────
SENTRY_DSN_BTC_ASSETS=

# ─── unipass-wallet-relayer ─────────────────────────────────────────
# 32-byte hex (64 chars) EVM-style private key. DEVNET/TESTNET ONLY.
# Generate once with: openssl rand -hex 32
RELAYER_PRIVATE_KEY=
# Opaque random string — clients must send `X-API-Key: <this>`.
# Generate with: openssl rand -hex 32
RELAYER_API_KEY=
# Comma-separated, e.g. https://app.example.com,https://staging.example.com
RELAYER_CORS_ORIGINS=

# ─── utxoswap-farm-sequencer ────────────────────────────────────────
# Opaque random string for the /admin endpoints.
FARM_API_KEY=
# Comma-separated CKB addresses allowed to call admin routes. Empty = none.
FARM_ADMIN_ADDRESSES=
# Comma-separated admin public keys (hex).
FARM_ADMIN_PUBKEYS=
FARM_CORS_ORIGINS=

# ─── huehub-token-distributor ───────────────────────────────────────
# Left `false` by default: workers will NOT broadcast xUDT transfers
# to CKB. Flip to `true` only against devnet once all CKB_* vars below
# are filled in.
ENABLE_CKB_SUBMISSION=false
# 32-byte hex (64 chars). DEVNET ONLY for rehearsal.
DISTRIBUTOR_PRIVATE_KEY=
DISTRIBUTOR_API_KEY=
# CKB address owned by DISTRIBUTOR_PRIVATE_KEY (issuer of the xUDT).
CKB_DISTRIBUTOR_ADDRESS=
DISTRIBUTOR_CORS_ORIGINS=
