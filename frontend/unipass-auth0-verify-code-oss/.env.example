# Auth0 Passwordless tenant — required in production. Copy to `.env.local`
# (gitignored) and fill in from your Auth0 dashboard.
#
# In development, if these are UNSET the verify route degrades to a
# dev-only magic code (`123456` → success, everything else → bad-code).
# In production, missing any of these causes `POST /api/verify` to
# return 500 `{ "error": "misconfigured", "missing": [...] }`.
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Optional: override the default realm (`email`). Set to `sms` if your
# passwordless connection is phone-based.
# AUTH0_REALM=email
