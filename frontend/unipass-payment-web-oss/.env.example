# Paymaster JSON-RPC URL (backend-rust/paymaster-service-oss).
# Expected to answer `pm_supportedEntryPoints` and
# `pm_sponsorUserOperation` per ERC-4337.
VITE_PAYMASTER_RPC_URL=http://localhost:3100/

# Default ERC-4337 EntryPoint. Fetched at runtime from
# `pm_supportedEntryPoints` if unset.
# VITE_DEFAULT_ENTRY_POINT=0x0000000071727De22E5E9d8BAf0edAc6f37da032
