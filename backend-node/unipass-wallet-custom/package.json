{
  "name": "unipass_wallet_backend",
  "version": "8.0.0",
  "description": " unipass wallet backend ",
  "author": "aven <aven@lay2.com>",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "start:dev": "nest start --watch",
    "build:prod": "tsc -p tsconfig.build.json",
    "start:prod": "node dist/main.js",
    "migration:generate": "yarn run typeorm migration:generate -d src/database/migrations -n",
    "migration:create": "typeorm migration:create src/database/migrations/",
    "migration:revert": "yarn run typeorm migration:revert",
    "schema:drop": "yarn run typeorm schema:drop",
    "watch:dev": "nodemon --config nodemon.json",
    "debug:dev": "nodemon --config nodemon-debug.json",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint --fix . --ext .ts",
    "test": "NODE_ENV=test jest",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:cov": "NODE_ENV=test jest --coverage",
    "test:debug": "NODE_ENV=test node --inspect-brk -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "NODE_ENV=test jest --config ./test/jest-e2e.json",
    "docs:dev": "vuepress dev -p 7070",
    "docs:build": "DEPLOY_ENV=gh-pages vuepress build",
    "docs:deploy": "yarn docs:build && gh-pages -d .vuepress/dist",
    "prepare": "husky install",
    "docker:build": "docker build -t wallet-backend .",
    "docker:run": "docker run -d -p 3001:3001 -v wallet-backend-logs:/app/wallet-backend-logs/logs --env-file=.env --name=wallet-backend --restart=always --cpu-shares 1024 --memory 1024M wallet-backend"
  },
  "dependencies": {
    "@anchan828/nest-sendgrid": "^0.5.49",
    "@nanogiants/nestjs-swagger-api-exception-decorator": "^1.6.0",
    "@nestjs/axios": "^0.0.4",
    "@nestjs/bull": "^0.6.3",
    "@nestjs/common": "^9.4.2",
    "@nestjs/config": "^1.1.6",
    "@nestjs/core": "^9.4.2",
    "@nestjs/cqrs": "^9.0.3",
    "@nestjs/jwt": "^10.0.1",
    "@nestjs/microservices": "^9.4.2",
    "@nestjs/passport": "^9.0.3",
    "@nestjs/platform-express": "^8.2.5",
    "@nestjs/swagger": "^5.1.5",
    "@nestjs/terminus": "^9.2.2",
    "@nestjs/typeorm": "^9.0.1",
    "@simplewebauthn/server": "^7.0.1",
    "@simplewebauthn/typescript-types": "^7.0.0",
    "@types/node-rsa": "^1.1.1",
    "@unipasswallet/sdk": "^0.2.2",
    "bull": "^4.10.4",
    "cache-manager": "^4.0.1",
    "cache-manager-redis-store": "^2.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0 ",
    "compression": "^1.7.4",
    "ethers": "^5.8.0",
    "express": "^4.17.2",
    "express-ctx": "^0.1.1",
    "express-rate-limit": "^5.5.1",
    "helmet": "^4.6.0",
    "jwt-simple": "^0.5.6",
    "lodash": "^4.17.21",
    "makerdao-multicall": "^0.12.5",
    "morgan": "^1.10.0",
    "mysql2": "^2.3.3",
    "node-apollo": "^1.2.1",
    "node-rsa": "^1.1.1",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "querystringify": "^2.2.0",
    "rxjs": "^7.5.2",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^4.3.0",
    "tss-wasm-node": "^0.6.0",
    "typeorm": "^0.3.15",
    "typeorm-naming-strategies": "^4.1.0",
    "typeorm-transactional-cls-hooked": "^0.1.21",
    "uuid": "^9.0.0",
    "winston": "^3.7.2",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^9.4.2",
    "@nestjs/testing": "^9.4.2",
    "@types/cache-manager-redis-store": "^2.0.1",
    "@types/compression": "^1.7.2",
    "@types/express": "^4.17.13",
    "@types/express-rate-limit": "^5.1.3",
    "@types/faker": "^5.5.9",
    "@types/jest": "^27.4.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/lodash": "^4.14.178",
    "@types/mime-types": "^2.1.1",
    "@types/morgan": "^1.9.3",
    "@types/node": "^16.11.12",
    "@types/passport-jwt": "^3.0.6",
    "@types/querystringify": "^2.0.0",
    "@types/speakeasy": "^2.0.7",
    "@types/supertest": "^2.0.11",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^5.9.1",
    "@typescript-eslint/parser": "^5.9.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.7.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-import-resolver-typescript": "^2.5.0",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-import-helpers": "^1.2.1",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "eslint-plugin-sonarjs": "^0.11.0",
    "eslint-plugin-unicorn": "^39.0.0",
    "gh-pages": "^3.2.3",
    "husky": "^7.0.4",
    "jest": "^27.4.7",
    "lint-staged": "~12.1.7",
    "nodemon": "^2.0.15",
    "prettier": "^2.5.0",
    "supertest": "^6.2.1",
    "ts-jest": "^27.1.2",
    "ts-loader": "^9.2.6",
    "ts-node": "^10.4.0",
    "typescript": "^4.5.4",
    "vuepress": "^2.0.0-beta.33"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "./test",
    "testRegex": "util.spec.ts$",
    "testTimeout": 5000000,
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "dotenv/config"
    ]
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "git add"
    ]
  }
}
