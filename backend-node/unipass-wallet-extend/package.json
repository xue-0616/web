{
  "name": "unipass-wallet-extend",
  "version": "0.0.1",
  "description": "unipass wallet extend server",
  "author": "aven@lay2.dev",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@apollo/gateway": "^0.28.0",
    "@graphql-tools/utils": "^7.10.0",
    "@nestjs/axios": "^2.0.0",
    "@nestjs/common": "^8.2.5",
    "@nestjs/config": "^1.1.6",
    "@nestjs/core": "^8.2.5",
    "@nestjs/graphql": "^7.10.6",
    "@nestjs/platform-express": "^9.3.9",
    "@nestjs/schedule": "^0.4.3",
    "@nestjs/swagger": "^6.2.1",
    "@nestjs/throttler": "^2.0.0",
    "@nestjs/typeorm": "^7.1.5",
    "@nextnm/nestjs-mailgun": "^1.1.1",
    "@sendgrid/mail": "^7.4.7",
    "@types/mailparser": "^3.0.2",
    "@types/node-rsa": "^1.1.1",
    "@types/request-ip": "^0.0.37",
    "@unipasswallet/popup-utils": "^1.1.1",
    "@unipasswallet/sdk": "^0.3.0-alpha.9",
    "apollo-server-errors": "^3.1.0",
    "apollo-server-express": "^2.24.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.0.3",
    "ethers": "^5.8.0",
    "express": "^4.18.2",
    "graphql": "^15.5.0",
    "graphql-tools": "^7.0.4",
    "ioredis": "^5.2.5",
    "makerdao-multicall": "^0.12.5",
    "moment": "^2.29.1",
    "nest-logger": "^6.2.0",
    "nestjs-real-ip": "^2.0.0",
    "node-rsa": "^1.1.1",
    "redis": "^3.1.2",
    "reflect-metadata": "^0.1.13",
    "request-ip": "^2.1.3",
    "rimraf": "^3.0.2",
    "rxjs": "^6.6.3",
    "typeorm": "^0.3.12",
    "typeorm-naming-strategies": "^4.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^8.2.0",
    "@nestjs/schematics": "^7.1.3",
    "@nestjs/testing": "^7.5.1",
    "@types/bcrypt": "^3.0.1",
    "@types/cache-manager": "^3.4.0",
    "@types/crypto-js": "^4.0.2",
    "@types/express": "^4.17.8",
    "@types/jest": "^26.0.15",
    "@types/node": "^18.11.18",
    "@types/node-rsa": "^1.1.1",
    "@types/supertest": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^5.9.1",
    "@typescript-eslint/parser": "^5.9.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^7.12.1",
    "eslint-config-prettier": "7.1.0",
    "eslint-import-resolver-typescript": "^2.5.0",
    "eslint-plugin-prettier": "^3.1.4",
    "jest": "^26.6.3",
    "mysql": "^2.18.1",
    "prettier": "^2.1.2",
    "supertest": "^6.0.0",
    "ts-jest": "^26.4.3",
    "ts-loader": "^8.0.8",
    "ts-node": "^9.0.0",
    "tsconfig-paths": "^3.9.0",
    "typescript": "^4.5.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "test",
    "testRegex": "app.api.spec.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
